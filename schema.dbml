  kit_category_id bigint
  kit_class_id bigint
  is_primary boolean
  squad_number int
  player_name text
  Indexes {
    (club_id) [name: 'idx_product_team_meta_club_id']
    (product_id) [name: 'idx_product_team_meta_product_id']
    (season_id) [name: 'idx_product_team_meta_season_id']
  }
}

Table pim.product_type {
  product_type_id int [pk]
  product_type_name text [not null]
}

Table pim.rivalry_intensity_ref {
  band_id bigint [pk, increment]
  label text [not null]
