// PIM schema (DBML)
// Generated from live database (schema=pim)
// Compatible with dbdiagram.io

Table pim.alumio_sync_log {
  id bigint [pk, increment]
  request_data jsonb
  response_data jsonb
  http_status_code int [not null]
  response_message text
  skus text[]
  operation_type jsonb
  error_source text
  task_id text
  duration real
  retry_number int
  created_at timestamp [not null, default: `now()`]
  Indexes {
    (created_at) [name: 'idx_alumio_sync_log_created_at']
  }
}

Table pim.alumio_sync_queue {
  id bigint [pk, increment]
  product_id bigint [not null]
  operation_type text [not null]
  status text [not null, default: 'pending']
  created_at timestamp [not null, default: `now()`]
  processed_at timestamp
  Indexes {
    (created_at) [name: 'alumio_sync_queue_v2_created_at_idx']
    (product_id) [name: 'alumio_sync_queue_v2_product_idx']
    (status) [name: 'alumio_sync_queue_v2_status_idx']
  }
}

Table pim.api_key {
  api_key_id bigint [pk, increment]
  name text [not null]
  key_hash text [not null]
  key_prefix text [not null]
  scopes text[] [not null]
  active boolean [not null, default: `true`]
  last_used_at timestamp
  created_at timestamp [not null, default: `now()`]
  created_by bigint
  Indexes {
    (key_hash) [name: 'api_key_key_hash_key', unique]
    (created_by) [name: 'idx_api_key_created_by']
  }
}

Table pim.app_permission {
  app_permission_id bigint [pk, increment]
  code text [not null]
  name text [not null]
  description text
  Indexes {
    (code) [name: 'app_permission_code_key', unique]
  }
}

Table pim.app_role {
  app_role_id bigint [pk, increment]
  code text [not null]
  name text [not null]
  description text
  is_system boolean [default: `false`]
  created_at timestamp
  updated_at timestamp
  Indexes {
    (code) [name: 'app_role_code_key', unique]
  }
}

Table pim.app_role_permission {
  app_role_id bigint [not null]
  app_permission_id bigint [not null]
  Indexes {
    (app_role_id, app_permission_id) [pk]
  }
}

Table pim.app_session {
  app_session_id bigint [pk, increment]
  app_user_id bigint [not null]
  session_token_hash text [not null]
  created_at timestamp [not null]
  expires_at timestamp [not null]
  revoked_at timestamp
  user_agent text
  ip_address text
  Indexes {
    (session_token_hash) [name: 'app_session_session_token_hash_key', unique]
    (app_user_id) [name: 'idx_app_session_app_user_id']
  }
}

Table pim.app_user {
  app_user_id bigint [pk, increment]
  email text
  google_sub text
  display_name text
  given_name text
  family_name text
  avatar_url text
  status text [not null]
  last_login_at timestamp
  created_at timestamp
  updated_at timestamp
  Indexes {
    (email) [name: 'app_user_email_key', unique]
    (google_sub) [name: 'app_user_google_sub_key', unique]
    (email) [name: 'idx_app_user_email']
    (google_sub) [name: 'idx_app_user_google_sub']
  }
}

Table pim.app_user_role {
  app_user_id bigint [not null]
  app_role_id bigint [not null]
  assigned_at timestamp
  assigned_by bigint
  assigned_reason text
  Indexes {
    (app_user_id, app_role_id) [pk]
  }
}

Table pim.attribute_def {
  attribute_id bigint [pk, increment]
  code text [not null]
  label text
  data_type text
  magento_sync boolean [default: `false`]
  magento_scope text [not null, default: 'global']
  Indexes {
    (code) [name: 'attribute_def_code_key', unique]
  }
}

Table pim.audit_event {
  audit_event_id bigint [pk, increment]
  actor_user_id bigint
  action text [not null]
  entity_type text
  entity_id text
  diff_json jsonb
  created_at timestamp [not null]
  Indexes {
    (actor_user_id) [name: 'idx_audit_event_actor_user_id']
    (created_at) [name: 'idx_audit_event_created_at']
    (entity_type, entity_id) [name: 'idx_audit_event_entity']
  }
}

Table pim.auth_identity {
  auth_identity_id bigint [pk, increment]
  app_user_id bigint [not null]
  provider text [not null]
  provider_subject text [not null]
  provider_email text
  provider_payload jsonb
  created_at timestamp
  updated_at timestamp
  Indexes {
    (provider, provider_subject) [name: 'auth_identity_provider_provider_subject_key', unique]
    (app_user_id) [name: 'idx_auth_identity_app_user_id']
  }
}

Table pim.brands {
  brand_id int [pk]
  brand_grouping text
  brand_name text [not null]
}

Table pim.category {
  category_id bigint [pk, increment]
  parent_id bigint
  name text [not null]
  path_key text [not null]
  Indexes {
    (path_key) [name: 'category_path_key_key', unique]
    (parent_id) [name: 'idx_category_parent_id']
  }
}

Table pim.channel {
  channel_id bigint [pk, increment]
  code text [not null]
  name text
  Indexes {
    (code) [name: 'channel_code_key', unique]
  }
}

Table pim.club {
  club_id bigint [pk, increment]
  name text [not null]
  country text
  founded_year int
  Indexes {
    (name) [name: 'club_name_key', unique]
  }
}

Table pim.club_rivalry {
  club_rivalry_id bigint [pk, increment]
  club_id_a bigint [not null]
  club_id_b bigint [not null]
  rivalry_type_id bigint
  known_as text
  intensity smallint
  period_start date
  period_end date
  is_primary boolean
  notes text
  Indexes {
    (club_id_a, club_id_b, rivalry_type_id, period_start, period_end) [name: 'club_rivalry_club_id_a_club_id_b_rivalry_type_id_period_sta_key', unique]
    (club_id_a, club_id_b) [name: 'idx_club_rivalry_pair']
    (period_start, period_end) [name: 'idx_club_rivalry_period']
    (rivalry_type_id) [name: 'idx_club_rivalry_type']
  }
}

Table pim.club_rivals_expanded {
  club_rivalry_id bigint [not null]
  club_id bigint [not null]
  rival_club_id bigint [not null]
  rivalry_type_id bigint
  known_as text
  intensity smallint
  period_start date
  period_end date
  is_primary boolean
  notes text
  Indexes {
    (club_id) [name: 'idx_club_rivals_expanded_club_id']
    (rival_club_id) [name: 'idx_club_rivals_expanded_rival_club_id']
  }
}

Table pim.competition {
  competition_id bigint [pk, increment]
  name text [not null]
  country text
  Indexes {
    (name) [name: 'competition_name_key', unique]
  }
}

Table pim.condition {
  condition_id int [pk]
