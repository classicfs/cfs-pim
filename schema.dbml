}

Table pim.store_currency {
  store_id bigint [not null]
  currency_id bigint [not null]
  is_default boolean
  Indexes {
    (store_id, currency_id) [pk]
  }
}

Table pim.tax_class {
  tax_class_id bigint [pk, increment]
  tax_class_name text [not null]
  Indexes {
    (tax_class_name) [name: 'tax_class_tax_class_name_key', unique]
  }
}

Table pim.warehouse {
  warehouse_id bigint [pk, increment]
  code text [not null]
  name text
  Indexes {
    (code) [name: 'warehouse_code_key', unique]
  }
}

Table pim.workspace_setting {
  key text [pk]
  value jsonb [not null]
  updated_at timestamp [default: `now()`]
}

