  label text
  sort_order int
  Indexes {
    (product_id) [name: 'idx_image_asset_product_id']
    (role) [name: 'idx_image_asset_role']
  }
}

Table pim.import_error {
  import_error_id bigint [pk, increment]
  import_row_id bigint [not null]
  field_key text
  error_code text
  error_message text
  meta_json jsonb
  created_at timestamp
  Indexes {
    (import_row_id) [name: 'idx_import_error_row_id']
  }
}

Table pim.import_job {
  import_job_id bigint [pk, increment]
  created_by bigint
  source_type text
  import_type text [not null]
  status text [not null]
  original_filename text
  file_sha256 text
  total_rows int
  valid_rows int
  invalid_rows int
  applied_rows int
  created_at timestamp
  updated_at timestamp
  applied_at timestamp
  Indexes {
    (created_by) [name: 'idx_import_job_created_by']
    (status) [name: 'idx_import_job_status']
  }
}

Table pim.import_row {
  import_row_id bigint [pk, increment]
  import_job_id bigint [not null]
  row_number int [not null]
  row_raw jsonb [not null]
  row_normalized jsonb
  row_status text [not null]
  row_key text
  created_at timestamp
  updated_at timestamp
  Indexes {
    (import_job_id) [name: 'idx_import_row_job_id']
    (import_job_id, row_status) [name: 'idx_import_row_job_status']
    (import_job_id, row_number) [name: 'import_row_import_job_id_row_number_key', unique]
  }
}

Table pim.kit_category {
  kit_category_id bigint [pk, increment]
  name text [not null]
  Indexes {
    (name) [name: 'kit_category_name_key', unique]
  }
}

Table pim.kit_class {
  kit_class_id bigint [pk, increment]
  name text [not null]
  Indexes {
    (name) [name: 'kit_class_name_key', unique]
  }
}

Table pim.payloads {
  id bigint [pk, increment]
  payload_type text
  last_run_date timestamp
  payload_location text
}

Table pim.product {
  product_id bigint [pk, increment]
  sku text [not null]
  parent_sku text
  article_number text
  product_type text [not null, default: 'simple']
  name text
  product_description text
  product_colour_id bigint
  gender_id bigint
  era_id bigint
  brand_id int
  product_type_id int
  product_style text
  size_id bigint
  condition_id int
  condition_detail text
  barcode text
  weight numeric(12,3)
  width_cm int
  length_cm int
  depth numeric(12,3)
  cost_price numeric(12,2)
  average_cost_price numeric(12,2)
  customer_price numeric(12,2)
  tax_class_id bigint
  composition text
  country_of_manufacture text
  commodity_code text
  image_code text
  printed boolean
  magento_product_id int
  enabled boolean
  sync boolean [default: `false`]
  created_at timestamp
  updated_at timestamp
  updated_by bigint
  Indexes {
    (brand_id) [name: 'idx_product_brand_id']
    (enabled) [name: 'idx_product_enabled']
    `parent_sku IS NOT NULL` [name: 'idx_product_parent_sku']
    (product_type_id) [name: 'idx_product_product_type_id']
    `sync = true` [name: 'idx_product_sync']
    (product_type) [name: 'idx_product_type']
    (barcode) [name: 'product_barcode_key', unique]
    (sku) [name: 'product_sku_key', unique]
  }
}

Table pim.product_attribute_val {
  product_id bigint [not null]
  attribute_id bigint [not null]
  value_text text
  value_num numeric
  value_bool boolean
  value_json jsonb
  product_attribute_val_id bigint [pk, increment]
  store_id bigint
  Indexes {
    (attribute_id) [name: 'idx_product_attribute_val_attribute_id']
    (product_id) [name: 'idx_product_attribute_val_product_id']
    `store_id IS NOT NULL` [name: 'idx_product_attribute_val_store_id']
  }
}

Table pim.product_barcode {
  product_barcode_id bigint [pk, increment]
  product_id bigint
  barcode_type text
  barcode_value text [not null]
  is_primary boolean
  status text
  source text
  verified_at timestamp
  created_at timestamp
  Indexes {
    (product_id) [name: 'idx_product_barcode_product_id']
    (status) [name: 'idx_product_barcode_status']
    (barcode_value) [name: 'product_barcode_barcode_value_key', unique]
  }
}

Table pim.product_category {
  product_id bigint [not null]
  category_id bigint [not null]
  Indexes {
    (product_id, category_id) [pk]
    (category_id) [name: 'idx_product_category_category_id']
  }
}

Table pim.product_channel_id {
  product_id bigint [not null]
  channel_id bigint [not null]
  external_product_id text
  Indexes {
    (product_id, channel_id) [pk]
    (channel_id) [name: 'idx_product_channel_id_channel_id']
    (external_product_id) [name: 'idx_product_channel_id_external_id']
  }
}

Table pim.product_colour {
  product_colour_id bigint [pk, increment]
  magento_colour_id text
  magento_colour_name text
  brand_id int
  brand_colour_id int
  brand_colour_name text
  Indexes {
    (brand_id) [name: 'idx_product_colour_brand_id']
  }
}

Table pim.product_group {
  product_group_id bigint [pk, increment]
  name text [not null]
  description text
  status text [not null]
  is_system boolean [not null, default: `false`]
  created_at timestamp
  updated_at timestamp
  created_by bigint
  updated_by bigint
  Indexes {
    (status) [name: 'idx_product_group_status']
  }
}

Table pim.product_group_member {
  product_group_member_id bigint [pk, increment]
  product_group_id bigint [not null]
  product_id bigint [not null]
  added_at timestamp
  added_by bigint
  start_date timestamp
  end_date timestamp
  live boolean [not null, default: `true`]
  Indexes {
    (live) [name: 'idx_product_group_member_live']
    (product_group_id) [name: 'idx_product_group_member_product_group_id']
    (product_id) [name: 'idx_product_group_member_product_id']
  }
}

Table pim.product_price {
  product_price_id bigint [pk, increment]
  product_id bigint [not null]
  currency_id bigint [not null]
  cost_price numeric(12,2)
  average_cost_price numeric(12,2)
  retail_price numeric(12,2)
  special_retail_price numeric(12,2)
  customer_price numeric(12,2)
  is_manual_override boolean [default: `false`]
  valid_from timestamp
  valid_to timestamp
  store_id bigint
  rrp numeric(12,2)
  printing_cost numeric(12,2)
  Indexes {
    (product_id, currency_id, store_id) [name: 'product_price_product_currency_idx']
  }
}

Table pim.product_sizes {
  size_id bigint [pk, increment]
  magento_size_id int
  magento_size_short_name text
  magento_size_long_name text
  config_options jsonb
  sizing_category text
}

Table pim.product_stock {
  product_id bigint [not null]
  warehouse_id bigint [not null]
  qty int
  bin_location text
  last_counted_at timestamp
  Indexes {
    (product_id, warehouse_id) [pk]
    (warehouse_id) [name: 'idx_product_stock_warehouse_id']
  }
}

Table pim.product_store {
  product_id bigint [not null]
  store_id bigint [not null]
  enabled boolean [default: `true`]
  created_at timestamp [default: `now()`]
  Indexes {
    (product_id, store_id) [pk]
    (store_id) [name: 'idx_product_store_store_id']
  }
}

Table pim.product_team_meta {
  product_team_meta_id bigint [pk, increment]
