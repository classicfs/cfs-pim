}

Table pim.currency {
  currency_id bigint [pk, increment]
  code text [not null]
  name text
  symbol text
  minor_unit smallint
  enabled boolean
  Indexes {
    (code) [name: 'currency_code_key', unique]
    (code) [name: 'idx_currency_code']
  }
}

Table pim.currency_conversion_rate {
  conversion_rate_id bigint [pk, increment]
  from_currency_id bigint [not null]
  to_currency_id bigint [not null]
  rate numeric(12,6) [not null]
  updated_at timestamp
  Indexes {
    (from_currency_id, to_currency_id) [name: 'currency_conversion_rate_from_currency_id_to_currency_id_key', unique]
  }
}

Table pim.department {
  department_id bigint [pk, increment]
  name text [not null]
  Indexes {
    (name) [name: 'department_name_key', unique]
  }
}

Table pim.era {
  era_id bigint [pk, increment]
  name text [not null]
  start_year int [not null]
  end_year int [not null]
  Indexes {
    (name) [name: 'era_name_key', unique]
  }
}

Table pim.gender {
  gender_id bigint [pk, increment]
  gender_name text [not null]
}

Table pim.image_asset {
  image_id bigint [pk, increment]
  product_id bigint
