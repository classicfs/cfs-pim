  max_score smallint [not null]
}

Table pim.rivalry_type {
  rivalry_type_id bigint [pk, increment]
  code text [not null]
  name text [not null]
  description text
  Indexes {
    (code) [name: 'rivalry_type_code_key', unique]
  }
}

Table pim.scheduled_change {
  id bigint [pk, increment]
  name text [not null]
  description text
  scheduled_at timestamp [not null]
  ends_at timestamp
  status text [not null, default: 'pending']
  scope_type text [not null]
  scope_group_id bigint
  created_by bigint
  created_at timestamp [default: `now()`]
  updated_at timestamp [default: `now()`]
  applied_at timestamp
  reverted_at timestamp
  error_message text
  Indexes {
    (scheduled_at) [name: 'idx_scheduled_change_scheduled_at']
    (status) [name: 'idx_scheduled_change_status']
    (scheduled_at) [name: 'scheduled_change_scheduled_at_idx']
    (status) [name: 'scheduled_change_status_idx']
  }
}

Table pim.scheduled_change_item {
  id bigint [pk, increment]
  scheduled_change_id bigint [not null]
  product_id bigint
  entity_type text [not null]
  field_name text [not null]
  new_value text
  old_value text
  change_mode text [default: 'absolute']
  status text [not null, default: 'pending']
  error_message text
  Indexes {
    (scheduled_change_id) [name: 'scheduled_change_item_change_idx']
    (scheduled_change_id) [name: 'scheduled_change_item_v2_change_idx']
    (product_id) [name: 'scheduled_change_item_v2_product_idx']
    (status) [name: 'scheduled_change_item_v2_status_idx']
  }
}

Table pim.season {
  season_id bigint [pk, increment]
  code text [not null]
  year_start int [not null]
